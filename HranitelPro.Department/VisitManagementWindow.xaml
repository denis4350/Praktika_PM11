<Window x:Class="HranitelPro.Department.VisitManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление посещением" 
        Height="565" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4CAF50" Padding="10" CornerRadius="5">
            <TextBlock Text="📋 Управление посещением" FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
            <StackPanel>
                <GroupBox Header="👤 Информация о посетителе" Margin="0,5">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                        <TextBlock x:Name="VisitorNameText" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0"/>

                        <TextBlock Text="Паспорт:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PassportText" Grid.Row="1" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Подразделение:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="DepartmentText" Grid.Row="2" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Сотрудник:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EmployeeText" Grid.Row="3" Grid.Column="1" Margin="10,8,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="⏱️ Фиксация времени" Margin="0,10">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Время входа:" FontWeight="Bold"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBox x:Name="EntryTimeBox" Width="100" Text="HH:MM" Margin="0,0,10,0"/>
                            <Button x:Name="EntryButton" Content="✅ ЗАФИКСИРОВАТЬ ВХОД" 
                                    Click="EntryButton_Click"
                                    Background="#4CAF50" Foreground="White" Width="180" Height="35"/>
                        </StackPanel>

                        <TextBlock Text="Время выхода:" FontWeight="Bold" Margin="0,15,0,0"/>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBox x:Name="ExitTimeBox" Width="100" Text="HH:MM" Margin="0,0,10,0"/>
                            <Button x:Name="ExitButton" Content="🚪 ЗАФИКСИРОВАТЬ ВЫХОД" 
                                    Click="ExitButton_Click"
                                    Background="#FF9800" Foreground="White" Width="180" Height="35"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Список посетителей для групповой заявки -->
                <GroupBox x:Name="VisitorsGroup" Header="👥 Список посетителей группы" Margin="0,10" Visibility="Collapsed">
                    <DataGrid x:Name="VisitorsGrid" Height="150" AutoGenerateColumns="True" Margin="10"/>
                </GroupBox>

                <!-- Контекстное меню для добавления в чёрный список -->
                <Border Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,10">
                    <StackPanel>
                        <TextBlock Text="⚠️ Правой кнопкой мыши по ФИО посетителя" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="→ можно добавить в ЧЁРНЫЙ СПИСКОК" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="ЗАКРЫТЬ" Click="Close_Click" 
                    Width="100" Height="35" Background="#9E9E9E" Foreground="White" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
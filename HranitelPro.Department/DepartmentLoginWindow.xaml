<Window x:Class="HranitelPro.Department.DepartmentLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал подразделения" 
        Height="400" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5" Margin="0,-25,0,-156">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4CAF50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🏢" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Сотрудник подразделения" 
                           FontSize="22" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
                <TextBlock Text="Управление посещениями" 
                           FontSize="12" 
                           Foreground="#E0E0E0" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="35,20,35,36" Background="White" CornerRadius="15" Padding="25">
            <StackPanel Margin="0,0,0,73">
                <TextBlock Text="Авторизация сотрудника" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="🔑 Код сотрудника" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                <PasswordBox x:Name="AuthCodeBox" Margin="0,5,0,20" Height="40" Padding="12,0"
                             BorderBrush="#DDD" BorderThickness="1" FontSize="13"/>

                <Button Content="ВОЙТИ" Click="Login_Click"
                        Background="#4CAF50" Foreground="White"
                        Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
        
                <TextBlock x:Name="StatusText" Text="Введите код сотрудника" 
                           FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
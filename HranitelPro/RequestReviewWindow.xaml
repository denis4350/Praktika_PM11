<Window x:Class="HranitelPro.RequestReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка заявки" 
        Height="600" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF9800" Padding="10" CornerRadius="5">
            <TextBlock Text="📋 Детальная проверка заявки" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Данные заявки -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
            <StackPanel>

                <!-- ИНФОРМАЦИЯ О ЗАЯВИТЕЛЕ -->
                <GroupBox Header="👤 ИНФОРМАЦИЯ О ЗАЯВИТЕЛЕ" Margin="0,5" FontWeight="Bold">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                        <TextBlock x:Name="FullNameText" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="Дата рождения:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="BirthDateText" Grid.Row="1" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Телефон:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PhoneText" Grid.Row="2" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Email:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EmailText" Grid.Row="3" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Паспорт:" Grid.Row="4" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PassportText" Grid.Row="4" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Организация:" Grid.Row="5" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="OrganizationText" Grid.Row="5" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Примечание:" Grid.Row="6" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="NoteText" Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" TextWrapping="Wrap"/>
                    </Grid>
                </GroupBox>

                <!-- ИНФОРМАЦИЯ О ПОСЕЩЕНИИ -->
                <GroupBox Header="📅 ИНФОРМАЦИЯ О ПОСЕЩЕНИИ" Margin="0,10" FontWeight="Bold">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Тип заявки:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                        <TextBlock x:Name="RequestTypeText" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0"/>

                        <TextBlock Text="Цель:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PurposeText" Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="Подразделение:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="DepartmentText" Grid.Row="2" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Сотрудник:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EmployeeText" Grid.Row="3" Grid.Column="1" Margin="10,8,0,0"/>

                        <TextBlock Text="Дата и время посещения:" Grid.Row="4" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="10,8,0,0">
                            <DatePicker x:Name="VisitDatePicker" Width="120" Margin="0,0,10,0"/>
                            <TextBox x:Name="VisitTimeBox" Width="80" Text="10:00"/>
                        </StackPanel>

                        <TextBlock Text="Статус:" Grid.Row="5" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <ComboBox x:Name="StatusCombo" Grid.Row="5" Grid.Column="1" Width="150" Margin="10,8,0,0" HorizontalAlignment="Left">
                            <ComboBoxItem Content="На проверке"/>
                            <ComboBoxItem Content="Одобрена"/>
                            <ComboBoxItem Content="Отклонена"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- ПРЕДУПРЕЖДЕНИЕ О ЧЁРНОМ СПИСКЕ -->
                <Border x:Name="BlacklistWarning" Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ ВНИМАНИЕ! ПОСЕТИТЕЛЬ В ЧЁРНОМ СПИСКЕ" 
                                   FontWeight="Bold" Foreground="Red" FontSize="14"/>
                        <TextBlock x:Name="BlacklistMessage" TextWrapping="Wrap" Margin="0,8,0,0" FontSize="12"/>
                        <TextBlock Text="Статус заявки автоматически изменён на 'Отклонена'"
                                   Margin="0,8,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="SaveButton" Content="✅ СОХРАНИТЬ ИЗМЕНЕНИЯ" 
                    Click="Save_Click" Width="180" Height="40" 
                    Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" Margin="5" Cursor="Hand"/>
            <Button Content="❌ ЗАКРЫТЬ" 
                    Click="Close_Click" Width="120" Height="40" 
                    Background="#9E9E9E" Foreground="White" 
                    FontWeight="Bold" Margin="5" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="HranitelPro.ChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Выбор типа посещения" 
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="200"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <TextBlock Text="Выберите тип посещения" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Кнопки выбора -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">

            <!-- Личное посещение -->
            <Button Click="PersonalVisit_Click">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Account" 
                                             Width="80" 
                                             Height="80" 
                                             Margin="0,20,0,10"/>
                    <TextBlock Text="Личное посещение" 
                               Margin="0,10,0,20"/>
                    <TextBlock Text="Один посетитель" 
                               FontSize="12" 
                               FontWeight="Normal"
                               Foreground="Gray"/>
                </StackPanel>
            </Button>

            <!-- Групповое посещение -->
            <Button Click="GroupVisit_Click">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroup" 
                                             Width="80" 
                                             Height="80" 
                                             Margin="0,20,0,10"/>
                    <TextBlock Text="Групповое посещение" 
                               Margin="0,10,0,20"/>
                    <TextBlock Text="Несколько посетителей" 
                               FontSize="12" 
                               FontWeight="Normal"
                               Foreground="Gray"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Window>
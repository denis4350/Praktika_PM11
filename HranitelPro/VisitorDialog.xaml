<Window x:Class="HranitelPro.VisitorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление посетителя" 
        Height="500" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Фамилия"/>
            <TextBox x:Name="LastNameBox" Margin="0,5"/>

            <TextBlock Text="Имя" Margin="0,10,0,0"/>
            <TextBox x:Name="FirstNameBox" Margin="0,5"/>

            <TextBlock Text="Отчество" Margin="0,10,0,0"/>
            <TextBox x:Name="MiddleNameBox" Margin="0,5"/>

            <TextBlock Text="Телефон" Margin="0,10,0,0"/>
            <TextBox x:Name="PhoneBox" Margin="0,5"/>

            <TextBlock Text="Email" Margin="0,10,0,0"/>
            <TextBox x:Name="EmailBox" Margin="0,5"/>

            <TextBlock Text="Серия паспорта" Margin="0,10,0,0"/>
            <TextBox x:Name="PassportSeriesBox" Margin="0,5"/>

            <TextBlock Text="Номер паспорта" Margin="0,10,0,0"/>
            <TextBox x:Name="PassportNumberBox" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button Content="Добавить" Click="Add_Click" Width="100" Margin="5"/>
                <Button Content="Отмена" Click="Cancel_Click" Width="100" Margin="5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
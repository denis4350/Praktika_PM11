<Window x:Class="HranitelPro.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" 
        Height="752" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>

        <Style x:Key="AuthButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" 
                                           FontSize="16" Margin="0,0,10,0"/>
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                BorderBrush="#CCC"
                                BorderThickness="1"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4CAF50" Offset="0"/>
                    <GradientStop Color="#388E3C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Регистрация" 
                           FontSize="24" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Карточка регистрации -->
        <Border Grid.Row="1" 
                Margin="35,20,35,30"
                Background="White"
                CornerRadius="15"
                Padding="25"
                Effect="{StaticResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Создание аккаунта" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#333"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Поле Email -->
                    <TextBlock Text="📧 Электронная почта" 
                               FontSize="12" 
                               Foreground="#666"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailBox" />

                    <!-- Поле Пароль -->
                    <TextBlock Text="🔒 Пароль" 
                               FontSize="12" 
                               Foreground="#666"
                               Margin="0,10,0,5"/>
                    <PasswordBox x:Name="PasswordBox"/>

                    <!-- Подсказка по паролю -->
                    <TextBlock x:Name="PasswordHint" 
                               Text="(мин. 8 символов, заглавные/строчные, цифры, спецсимволы)"
                               FontSize="10" 
                               Foreground="#999" 
                               Margin="0,-10,0,10"/>

                    <!-- Поле Подтверждение пароля -->
                    <TextBlock Text="🔒 Подтверждение пароля" 
                               FontSize="12" 
                               Foreground="#666"
                               Margin="0,5,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,5,0,15"/>

                    <!-- Способ 1: SQL запрос -->
                    <Button Content="Регистрация (SQL запрос)" 
                            Click="RegisterSQL_Click"
                            Background="#4CAF50"
                            Style="{StaticResource AuthButtonStyle}"
                            Tag="🔓"/>

                    <!-- Способ 2: Хранимая процедура -->
                    <Button Content="Регистрация (Хранимая процедура)" 
                            Click="RegisterProcedure_Click"
                            Background="#FF9800"
                            Style="{StaticResource AuthButtonStyle}"
                            Tag="⚙️"/>

                    <!-- Способ 3: ORM -->
                    <Button Content="Регистрация (ORM)" 
                            Click="RegisterORM_Click"
                            Background="#9C27B0"
                            Style="{StaticResource AuthButtonStyle}"
                            Tag="💾"/>

                    <!-- Разделитель -->
                    <Border Height="1" 
                            Background="#E0E0E0" 
                            Margin="0,15,0,15"/>

                    <!-- Кнопка назад -->
                    <Button Content="← Назад" 
                            Click="Back_Click"
                            Style="{StaticResource BackButtonStyle}"/>

                    <!-- Индикатор статуса -->
                    <TextBlock x:Name="StatusText" 
                               Text="Выберите способ регистрации" 
                               FontSize="11" 
                               Foreground="#999"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
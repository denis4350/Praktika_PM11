<Window x:Class="HranitelPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HranitelPro"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="ХранительПРО - Личная заявка" 
        Height="986" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
            <Setter Property="Padding" Value="0,5"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="0,0,10,10">
            <StackPanel>
                <TextBlock Text="📝 Оформление личной заявки" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Заполните все обязательные поля" 
                           FontSize="12" 
                           Foreground="#E0E0E0"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Margin="20" Background="White" CornerRadius="10" Padding="20" Effect="{StaticResource CardShadow}">
                <StackPanel>

                    <!-- Информация о посещении -->
                    <TextBlock Text="📅 ИНФОРМАЦИЯ О ПОСЕЩЕНИИ" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Дата начала *" FontSize="12" Foreground="#666"/>
                    <DatePicker x:Name="StartDate"/>

                    <TextBlock Text="Дата окончания *" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <DatePicker x:Name="EndDate"/>

                    <TextBlock Text="Цель посещения *" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBox x:Name="PurposeBox"/>

                    <!-- Принимающая сторона -->
                    <TextBlock Text="🏢 ПРИНИМАЮЩАЯ СТОРОНА" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Подразделение *" FontSize="12" Foreground="#666"/>
                    <ComboBox x:Name="DepartmentCombo" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Name"
                              SelectionChanged="DepartmentCombo_SelectionChanged"/>

                    <TextBlock Text="ФИО сотрудника *" FontSize="12" Foreground="#666"/>
                    <ComboBox x:Name="EmployeeCombo" 
                              DisplayMemberPath="FullName"
                              SelectedValuePath="FullName"
                              IsEnabled="False"/>

                    <!-- Информация о посетителе -->
                    <TextBlock Text="👤 ИНФОРМАЦИЯ О ПОСЕТИТЕЛЕ" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Фамилия *" FontSize="12" Foreground="#666"/>
                            <TextBox x:Name="LastNameBox"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="Имя *" FontSize="12" Foreground="#666"/>
                            <TextBox x:Name="FirstNameBox"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <TextBlock Text="Отчество" FontSize="12" Foreground="#666"/>
                            <TextBox x:Name="MiddleNameBox"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Дата рождения *" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <DatePicker x:Name="BirthDateBox"/>

                    <TextBlock Text="Телефон" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBox x:Name="PhoneBox"/>

                    <TextBlock Text="Email *" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBox x:Name="EmailBox"/>

                    <TextBlock Text="Организация" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBox x:Name="OrganizationBox"/>

                    <TextBlock Text="Примечание *" FontSize="12" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBox x:Name="NoteBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <!-- Паспортные данные -->
                    <TextBlock Text="🪪 ПАСПОРТНЫЕ ДАННЫЕ" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Серия паспорта *" FontSize="12" Foreground="#666"/>
                            <TextBox x:Name="PassportSeriesBox" MaxLength="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Номер паспорта *" FontSize="12" Foreground="#666"/>
                            <TextBox x:Name="PassportNumberBox" MaxLength="6"/>
                        </StackPanel>
                    </Grid>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="📤 ОТПРАВИТЬ ЗАЯВКУ" 
                                Click="CreateRequest_Click"
                                Background="#4CAF50" 
                                Foreground="White"
                                Width="200"
                                Style="{StaticResource ButtonStyle}"/>
                        <Button Content="📋 МОИ ЗАЯВКИ" 
                                Click="ViewRequests_Click"
                                Background="#2196F3" 
                                Foreground="White"
                                Width="150"
                                Margin="10,10,0,10"
                                Style="{StaticResource ButtonStyle}"/>
                    </StackPanel>

                    <!-- Статус -->
                    <TextBlock x:Name="StatusText" 
                               Text="Готово к заполнению" 
                               FontSize="11" 
                               Foreground="#999"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
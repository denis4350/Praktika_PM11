<Window x:Class="HranitelPro.GeneralDepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Общий отдел - проверка заявок" 
        Height="750" 
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF9800" Padding="10" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏢 Общий отдел - проверка заявок" 
                           FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="EmployeeInfo" Text="" FontSize="12" 
                           Foreground="#E0E0E0" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10" Margin="0,10,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Фильтры:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>

                <ComboBox x:Name="TypeFilter" Width="120" Margin="5" SelectionChanged="ApplyFilters">
                    <ComboBoxItem Content="Все типы" IsSelected="True"/>
                    <ComboBoxItem Content="Личная"/>
                    <ComboBoxItem Content="Групповая"/>
                </ComboBox>

                <ComboBox x:Name="DepartmentFilter" Width="150" Margin="5" SelectionChanged="ApplyFilters"/>

                <ComboBox x:Name="StatusFilter" Width="120" Margin="5" SelectionChanged="ApplyFilters">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="На проверке"/>
                    <ComboBoxItem Content="Одобрена"/>
                    <ComboBoxItem Content="Отклонена"/>
                </ComboBox>

                <Button Content="Сбросить" Click="ResetFilters_Click" 
                        Margin="20,5,5,5" Background="#FF9800" Foreground="White" Width="84"/>
                <Button Content="Обновить" Click="Refresh_Click" 
                        Margin="5,5,5,5" Background="#2196F3" Foreground="White" Width="112"/>
                <Button Content="📊 Отчёты" Click="OpenReports_Click" 
                        Background="#4CAF50" Foreground="White" Width="128"/>
                <Button Content="🔄 Обновить список на территории" Click="RefreshVisitorsList_Click" 
                        Margin="20,5,5,5" Background="#FF5722" Foreground="White" Width="286"/>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="5" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="📋 Список заявок" FontSize="14" FontWeight="Bold" Margin="5,0,0,5"/>
                <DataGrid x:Name="RequestsGrid" 
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" MouseDoubleClick="OnRequestDoubleClick"
                          AlternatingRowBackground="#F9F9F9" Height="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Width="50" Binding="{Binding RequestId}"/>
                        <DataGridTextColumn Header="Тип" Width="80" Binding="{Binding RequestType}"/>
                        <DataGridTextColumn Header="ФИО посетителя" Width="150" Binding="{Binding VisitorName}"/>
                        <DataGridTextColumn Header="Паспорт" Width="100" Binding="{Binding Passport}"/>
                        <DataGridTextColumn Header="Подразделение" Width="120" Binding="{Binding Department}"/>
                        <DataGridTextColumn Header="Сотрудник" Width="150" Binding="{Binding Employee}"/>
                        <DataGridTextColumn Header="Дата начала" Width="100" Binding="{Binding StartDate}"/>
                        <DataGridTextColumn Header="Дата окончания" Width="100" Binding="{Binding EndDate}"/>
                        <DataGridTextColumn Header="Цель" Width="150" Binding="{Binding Purpose}"/>
                        <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Разделитель -->
        <Border Grid.Row="3" Height="1" Background="#DDD" Margin="0,10"/>

        <!-- Список лиц на территории -->
        <Border Grid.Row="4" Background="White" CornerRadius="5" Padding="5" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="👥 Список лиц на территории" FontSize="14" FontWeight="Bold" Margin="5,0,0,5"/>
                <TextBlock x:Name="VisitorsCountText" Text="На территории: 0" 
                           FontSize="12" Foreground="Green" Margin="5,0,0,10"/>
                <DataGrid x:Name="CurrentVisitorsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Height="200" AlternatingRowBackground="#F9F9F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО посетителя" Width="200" Binding="{Binding VisitorName}"/>
                        <DataGridTextColumn Header="Подразделение" Width="180" Binding="{Binding Department}"/>
                        <DataGridTextColumn Header="Время входа" Width="150" Binding="{Binding EntryTime}"/>
                        <DataGridTextColumn Header="Тип заявки" Width="100" Binding="{Binding RequestType}"/>
                        <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="4" Background="#E0E0E0" Padding="5" Margin="0,10,0,0" CornerRadius="5" VerticalAlignment="Bottom">
            <TextBlock x:Name="StatusBar" Text="Готов к работе" FontSize="11" Foreground="#666"/>
        </Border>
    </Grid>
</Window>
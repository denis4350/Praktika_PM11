<Window x:Class="HranitelPro.GroupRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Групповая заявка" 
        Height="920" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <ScrollViewer>
            <StackPanel>

                <TextBlock Text="Оформление групповой заявки" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Основная информация -->
                <GroupBox Header="Информация о посещении" Margin="0,5">
                    <StackPanel Margin="10">
                        <TextBlock Text="Дата начала"/>
                        <DatePicker x:Name="StartDate" Margin="0,5"/>

                        <TextBlock Text="Дата окончания" Margin="0,10,0,0"/>
                        <DatePicker x:Name="EndDate" Margin="0,5"/>

                        <TextBlock Text="Цель посещения" Margin="0,10,0,0"/>
                        <TextBox x:Name="PurposeBox" Margin="0,5"/>

                        <TextBlock Text="Подразделение" Margin="0,10,0,0"/>
                        <TextBox x:Name="DepartmentBox" Margin="0,5"/>

                        <TextBlock Text="ФИО сотрудника" Margin="0,10,0,0"/>
                        <TextBox x:Name="EmployeeBox" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <!-- Список посетителей -->
                <GroupBox Header="Список посетителей" Margin="0,10">
                    <StackPanel Margin="10">
                        <DataGrid x:Name="VisitorsGrid" 
                                  AutoGenerateColumns="False" 
                                  Height="200" 
                                  Margin="0,5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Фамилия" Width="*" Binding="{Binding LastName}"/>
                                <DataGridTextColumn Header="Имя" Width="*" Binding="{Binding FirstName}"/>
                                <DataGridTextColumn Header="Отчество" Width="*" Binding="{Binding MiddleName}"/>
                                <DataGridTextColumn Header="Телефон" Width="*" Binding="{Binding Phone}"/>
                                <DataGridTextColumn Header="Email" Width="*" Binding="{Binding Email}"/>
                                <DataGridTextColumn Header="Серия паспорта" Width="*" Binding="{Binding PassportSeries}"/>
                                <DataGridTextColumn Header="Номер паспорта" Width="*" Binding="{Binding PassportNumber}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
                            <Button Content="Добавить посетителя" 
                                    Click="AddVisitor_Click" 
                                    Width="150" 
                                    Margin="5"/>
                            <Button Content="Удалить выбранного" 
                                    Click="RemoveVisitor_Click" 
                                    Width="150" 
                                    Margin="5"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <Button Content="Отправить заявку" 
                            Click="SubmitRequest_Click" 
                            Width="150" 
                            Height="40"
                            Margin="10"
                            Background="#4CAF50"
                            Foreground="White"/>
                    <Button Content="Назад" 
                            Click="Back_Click" 
                            Width="150" 
                            Height="40"
                            Margin="10"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
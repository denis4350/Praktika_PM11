<Window x:Class="HranitelPro.Security.SecurityAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Разрешение доступа" 
        Height="500" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="10" CornerRadius="5">
            <TextBlock Text="🛡️ Разрешение на доступ" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>
        
        <!-- Информация -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
            <StackPanel>
                <GroupBox Header="👤 Информация о посетителе" Margin="0,5">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                        <TextBlock x:Name="VisitorNameText" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0"/>
                        
                        <TextBlock Text="Паспорт:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PassportText" Grid.Row="1" Grid.Column="1" Margin="10,8,0,0"/>
                        
                        <TextBlock Text="Подразделение:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="DepartmentText" Grid.Row="2" Grid.Column="1" Margin="10,8,0,0"/>
                        
                        <TextBlock Text="Сотрудник:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EmployeeText" Grid.Row="3" Grid.Column="1" Margin="10,8,0,0"/>
                    </Grid>
                </GroupBox>
                
                <GroupBox Header="⏱️ Управление доступом" Margin="0,10">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Статус:" FontWeight="Bold"/>
                        <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,5,0,0"/>
                        
                        <TextBlock Text="Время входа:" FontWeight="Bold" Margin="0,15,0,0"/>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBox x:Name="EntryTimeBox" Width="100" Text="HH:MM" Margin="0,0,10,0"/>
                            <Button x:Name="EntryButton" Content="✅ ЗАФИКСИРОВАТЬ ВХОД" 
                                    Click="EntryButton_Click"
                                    Background="#4CAF50" Foreground="White" Width="180" Height="35"/>
                        </StackPanel>
                        
                        <TextBlock Text="Время " FontWeight="Bold" Margin="0,15,0,0"/>
                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBox x:Name="ExitTimeBox" Width="100" Text="HH:MM" Margin="0,0,10,0"/>
                            <Button x:Name="ExitButton" Content="🚪 ЗАФИКСИРОВАТЬ ВЫХОД" 
                                    Click="ExitButton_Click"
                                    Background="#FF9800" Foreground="White" Width="180" Height="35"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
                
                <!-- Оповещение о нарушении -->
                <Border x:Name="AlertBorder" Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ ВНИМАНИЕ! НАРУШЕНИЕ!" FontWeight="Bold" Foreground="Red" FontSize="14"/>
                        <TextBlock x:Name="AlertMessage" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="🔊 ОТКРЫТЬ ТУРНИКЕТ" Click="OpenTurnstile_Click" 
                    Width="150" Height="40" Background="#2196F3" Foreground="White" Margin="5"/>
            <Button Content="ЗАКРЫТЬ" Click="Close_Click" 
                    Width="100" Height="40" Background="#9E9E9E" Foreground="White" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
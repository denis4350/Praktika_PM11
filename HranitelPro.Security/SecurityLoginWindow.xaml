<Window x:Class="HranitelPro.Security.SecurityLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал охраны" 
        Height="459" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0" Background="#2196F3">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Служба охраны" 
                           FontSize="22" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
                <TextBlock Text="Терминал пропускного контроля" 
                           FontSize="12" 
                           Foreground="#E0E0E0" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Карточка входа -->
        <Border Grid.Row="1" 
                Margin="35,20,35,10"
                Background="White"
                CornerRadius="15"
                Padding="25">

            <StackPanel>
                <TextBlock Text="Авторизация сотрудника охраны" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="🔑 Код сотрудника" 
                           FontSize="12" 
                           Foreground="#666"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="AuthCodeBox" 
                             Margin="0,5,0,20" 
                             Height="40" 
                             Padding="12,0"
                             BorderBrush="#DDD"
                             BorderThickness="1"
                             FontSize="13"/>

                <Button Content="ВОЙТИ" 
                        Click="Login_Click"
                        Background="#2196F3" 
                        Foreground="White"
                        Height="45"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"/>

                <TextBlock x:Name="StatusText" 
                           Text="Введите код сотрудника охраны" 
                           FontSize="11" 
                           Foreground="#999"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
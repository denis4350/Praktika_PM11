<Window x:Class="HranitelPro.Security.SecurityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал охраны - пропускной контроль" 
        Height="650" 
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="10" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛡️ Терминал охраны - пропускной контроль" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="EmployeeInfo" 
                           Text="" 
                           FontSize="12" 
                           Foreground="#E0E0E0"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель поиска и фильтрации -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10" Margin="0,10" CornerRadius="5">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="SearchBox" Width="250" Margin="5" 
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Поиск по фамилии, имени, паспорту"/>
                    <Button Content="🔍 Найти" Click="Search_Click" 
                            Background="#2196F3" Foreground="White" Width="80" Margin="5"/>

                    <TextBlock Text="Фильтр по дате:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                    <DatePicker x:Name="DateFilter" Width="120" Margin="5" SelectedDateChanged="DateFilter_Changed"/>

                    <Button Content="Сбросить" Click="ResetFilters_Click" 
                            Margin="20,5,5,5" Background="#9E9E9E" Foreground="White" Width="80"/>
                    <Button Content="Обновить" Click="Refresh_Click" 
                            Margin="5,5,5,5" Background="#4CAF50" Foreground="White" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <DataGrid x:Name="RequestsGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="OnRequestDoubleClick"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding RequestId}"/>
                <DataGridTextColumn Header="Тип" Width="80" Binding="{Binding RequestType}"/>
                <DataGridTextColumn Header="ФИО посетителя" Width="150" Binding="{Binding VisitorName}"/>
                <DataGridTextColumn Header="Паспорт" Width="100" Binding="{Binding Passport}"/>
                <DataGridTextColumn Header="Подразделение" Width="120" Binding="{Binding Department}"/>
                <DataGridTextColumn Header="Сотрудник" Width="150" Binding="{Binding Employee}"/>
                <DataGridTextColumn Header="Дата посещения" Width="100" Binding="{Binding StartDate}"/>
                <DataGridTextColumn Header="Время входа" Width="100" Binding="{Binding EntryTime}"/>
                <DataGridTextColumn Header="Время выхода" Width="100" Binding="{Binding ExitTime}"/>
                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <Border Grid.Row="3" Background="#E0E0E0" Padding="5" Margin="0,10,0,0" CornerRadius="5">
            <TextBlock x:Name="StatusBar" Text="Готов к работе" FontSize="11" Foreground="#666"/>
        </Border>
    </Grid>
</Window>